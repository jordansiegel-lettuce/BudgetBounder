          }
        },
        "additionalProperties": false
      },
      "TransactionType": {
        "enum": [
          0,
          1
        ],
        "type": "integer",
        "format": "int32"
      },
      "User": {
        "required": [
          "email",
          "fullName",
          "passwordHash"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "fullName": {
            "minLength": 2,
            "type": "string"
          },
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "passwordHash": {
            "minLength": 3,
            "type": "string"
          },
          "level": {
            "type": "integer",
            "format": "int32"
          },
          "xp": {
